# ============================================================
# Clinic AI Agent - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub - it is already in .gitignore.
# Add all these variables to Railway dashboard under:
#   Your Service -> Variables
# ============================================================

# WhatsApp / Meta Cloud API
# Meta App -> WhatsApp -> API Setup -> Token
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxx

# Meta App -> WhatsApp -> API Setup -> Phone Number ID
WHATSAPP_PHONE_ID=123456789012345

# Any secret string you choose (used for webhook verification)
WHATSAPP_VERIFY_TOKEN=clinic_secret_abc_change_me

# OpenAI
# platform.openai.com -> API Keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# Model to use (gpt-4o-mini recommended for cost efficiency)
OPENAI_MODEL=gpt-4o-mini

# Supabase
# Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase Dashboard -> Settings -> API -> anon (public) key
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Clinic Info (displayed in messages to patients)
CLINIC_NAME=Dr. Sharma's Clinic
DOCTOR_NAME=Dr. Sharma
CLINIC_ADDRESS=123 MG Road, Mumbai - 400001

# Google Maps -> Your clinic -> Share -> Copy review link
GOOGLE_REVIEW_LINK=https://g.page/r/YOUR_CLINIC_ID/review
